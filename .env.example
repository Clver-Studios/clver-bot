# Discord Gateway Credentials
DISCORD_CLIENT_ID=your_discord_application_client_id_here
DISCORD_BOT_TOKEN=your_secret_discord_bot_token_here
DISCORD_GUILD_ID=your_target_development_guild_id_here

# Database Secret Parameters
DB_USER=clevr_admin
DB_PASSWORD=super_secret_password
DB_NAME=clevr_bot_db

# Connection URI targeting the internal Docker engine network DNS resolve name
DATABASE_URL=postgresql://clevr_admin:super_secret_password@clevr-db:5432/clevr_bot_db?schema=public

# Onboarding Gateway Configuration
ONBOARDING_CHANNEL_ID=paste_onboarding_channel_id_here
UNVERIFIED_ROLE_ID=paste_unverified_role_id_here

# Discovery Source Roles (Step 1)
ROLE_DISCOVERY_YOUTUBE=paste_role_id_here
ROLE_DISCOVERY_TWITTER=paste_role_id_here
ROLE_DISCOVERY_TIKTOK=paste_role_id_here
ROLE_DISCOVERY_INSTAGRAM=paste_role_id_here
ROLE_DISCOVERY_FRIEND=paste_role_id_here
ROLE_DISCOVERY_DISCORD=paste_role_id_here

# Platform Edition Roles (Step 2)
ROLE_PLATFORM_JAVA=paste_role_id_here
ROLE_PLATFORM_BEDROCK=paste_role_id_here

# Specialization Roles (Step 3)
ROLE_SPEC_DEV=paste_role_id_here
ROLE_SPEC_MODELER=paste_role_id_here
ROLE_SPEC_TEXTURE_ARTIST=paste_role_id_here
ROLE_SPEC_KEY_ARTIST=paste_role_id_here
ROLE_SPEC_BUILDER=paste_role_id_here