{
  "name": "clevr-bot",
  "version": "1.0.0",
  "description": "A scalable, 2026-optimized onboarding and announcement Discord bot",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "prisma db push && node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "prisma": "^7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
