datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model OnboardingState {
  userId        String   @id @map("user_id")
  currentStep   Int      @default(1) @map("current_step")
  platform      String?
  clients       String[]
  specialties   String[]
  notifications String[]
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("onboarding_states")
}

model AnnouncementConfig {
  id        String   @id @default(uuid())
  category  String   @unique
  hexColor  String   @map("hex_color")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcement_configs")
}

enum RepeatInterval {
  NONE
  DAILY
  WEEKLY
}

model ScheduledAnnouncement {
  id             String         @id @default(uuid())
  category       String
  title          String
  body           String
  channelId      String         @map("channel_id")
  sendAt         DateTime       @map("send_at")
  repeatInterval RepeatInterval @default(NONE) @map("repeat_interval")
  active         Boolean        @default(true)
  createdBy      String         @map("created_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  lastSentAt     DateTime?      @map("last_sent_at")

  @@map("scheduled_announcements")
}